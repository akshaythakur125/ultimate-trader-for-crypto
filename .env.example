# Ultimate Trader Configuration
# Copy this file to .env and fill in your values.

APP_NAME=Ultimate Trader
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///ultimate_trader.db

# Exchange API (only needed for live/paper trading)
BINGX_API_KEY=
BINGX_SECRET_KEY=

# Alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Mode
PAPER_TRADING_MODE=true
LIVE_TRADING_ENABLED=false

# Risk Limits
MAX_DAILY_DRAWDOWN_PERCENT=10

# Performance Targets
TARGET_MIN_PROFITABLE_OPPORTUNITIES_PER_DAY=2
TARGET_MAX_PROFITABLE_OPPORTUNITIES_PER_DAY=4

# Validation Thresholds
MIN_ACCEPTABLE_WIN_RATE=0.60
MIN_ACCEPTABLE_RR=3.0
PREFERRED_RR=5.0

# Scoring Thresholds
MIN_CONFIDENCE_SCORE=70
MAX_RISK_SCORE=40

# Holding Period
DEFAULT_HOLDING_TIME_MIN_HOURS=4
DEFAULT_HOLDING_TIME_MAX_HOURS=8
